# ============================================================
# django-meeting — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs
# ============================================================

# Clé secrète Django (OBLIGATOIRE en production — générer avec : python -c "import secrets; print(secrets.token_urlsafe(50))")
SECRET_KEY=changeme-use-a-long-random-string-in-production

# Mode debug : False en production, True en développement
DEBUG=False

# Hôtes autorisés (séparés par virgule)
# Exemple : mondomaine.com,www.mondomaine.com,localhost
ALLOWED_HOSTS=localhost,127.0.0.1

# Chemin vers la base de données SQLite
# En Docker : /data/db.sqlite3 (monté via bind mount ./db_data:/data)
# En développement : laisser vide pour utiliser BASE_DIR/db.sqlite3
DATABASE_PATH=/data/db.sqlite3
