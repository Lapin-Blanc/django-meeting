# Clé secrète Django (obligatoire en production)
SECRET_KEY=changeme-use-a-long-random-string-in-production

# Mode debug (True en développement, False en production)
DEBUG=False

# Hôtes autorisés (séparés par virgule, ex: mondomaine.com,www.mondomaine.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# Chemin vers la base de données SQLite (utilisé en Docker)
DATABASE_PATH=/data/db.sqlite3
