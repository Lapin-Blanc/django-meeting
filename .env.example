# ============================================================
# django-meeting — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs
# ============================================================
# Docker / Django

# Clé secrète Django (OBLIGATOIRE en production — générer avec : python -c "import secrets; print(secrets.token_urlsafe(50))")
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=

# Docker port publication (recommande pour cloudflared: 127.0.0.1)
DJANGO_BIND_HOST=127.0.0.1
DJANGO_PORT=8000

# Persistance (docker-compose monte ./data et ./media)
DJANGO_DB_PATH=/data/db.sqlite3
DJANGO_MEDIA_ROOT=/app/media
# Servir les uploads /media via Django (pratique en deploiement simple)
DJANGO_SERVE_MEDIA=1

# Securite / proxy (cloudflared)
DJANGO_USE_X_FORWARDED_HOST=1
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
# HSTS (0 = desactive; activer apres validation HTTPS stable)
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
DJANGO_SECURE_HSTS_PRELOAD=0

# Superuser auto (optionnel, au premier demarrage)
DJANGO_CREATE_SUPERUSER=0
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me